# Runtime data — content-addressed blob store + dated snapshots.
# This directory is operational data, not code. It lives outside git.
web_mirror/

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/

# Operational logs (written by cron / manual runs)
*.log
crawl.log

# SQLite access log — runtime data, not code
stats.db

# Temp / editor artifacts
*.swp
*.swo
*~
.DS_Store

# Local-only operational docs — infra, server access, runbook.
# MUST NOT be committed: this repo is PUBLIC. Anything matching stays local.
*.local.md
.local/

# Environment file — holds ARCHIVE_PASSWORD and other runtime secrets.
.env

# Ekimo integration guide — contains coordination details, not for public repo.
docs/plans/trigger-crawl-ekimo.md

# Deployment/operations docs with infra details — repo is PUBLIC.
DEPLOYMENT.md
OPERATIONS.md
